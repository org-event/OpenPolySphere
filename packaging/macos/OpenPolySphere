#!/bin/bash
# macOS app launcher — sets bundle paths and starts the server (or forwards CLI args).
set -euo pipefail

CONTENTS="$(cd "$(dirname "$0")/.." && pwd)"
RES="$CONTENTS/Resources"
FRAMEWORKS="$CONTENTS/Frameworks"
SUPPORT="$HOME/Library/Application Support/OpenPolySphere"

export CALL_TRANSLATOR_HOME="$RES"
export TRANSLATOR_DATA_DIR="$SUPPORT"
export ORT_DYLIB_PATH="${ORT_DYLIB_PATH:-$FRAMEWORKS/libonnxruntime.dylib}"
export POLYSPHERE_SPEECH_AUTH_APP="$RES/Helpers/PolySphereSpeech.app"

mkdir -p "$SUPPORT"

run_server() {
  "$RES/translator" serve &
  local pid=$!
  sleep 1
  open "http://127.0.0.1:5050" >/dev/null 2>&1 || true
  wait "$pid"
}

if [[ $# -eq 0 ]]; then
  run_server
elif [[ "$1" == "serve" ]]; then
  shift
  run_server
else
  exec "$RES/translator" "$@"
fi
